    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "eslint": "^8.57.0",
    "vitest": "^4.0.0",
    "@testing-library/react": "^16.0.0",
