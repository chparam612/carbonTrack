rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their OWN anonymous auth documents
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Logs subcollection — validate data shape and value ranges
    match /users/{userId}/logs/{logId} {
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasAll(['date', 'entries', 'total'])
                   && request.resource.data.total is number
                   && request.resource.data.total >= 0
                   && request.resource.data.total <= 1000;
    }
  }
}
